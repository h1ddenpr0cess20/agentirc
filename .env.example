IRC_HOST=irc.rizon.net
IRC_PORT=6667
IRC_NICK=mybot
IRC_USER=mybot
IRC_REALNAME=My IRC Bot
IRC_CHANNELS=#general,#bots
IRC_PASSWORD=
IRC_USE_TLS=false
IRC_CMD_PREFIX=!

# AI chatbot provider settings (used by: python -m chatbot)
OPENAI_API_BASE=https://api.openai.com
OPENAI_API_KEY=
OPENAI_MODELS=

XAI_API_BASE=https://api.x.ai/v1
XAI_API_KEY=
XAI_MODELS=

LMSTUDIO_BASE_URL=http://127.0.0.1:1234/v1
LMSTUDIO_API_KEY=
LMSTUDIO_MODELS=

DEFAULT_MODEL=gpt-5-mini
CHATBOT_TOOLS=web_search,x_search,code_interpreter
CHATBOT_ADMINS=
CHATBOT_SERVER_MODELS=true
CHATBOT_DEFAULT_PERSONALITY="a helpful IRC chatbot"
CHATBOT_PROMPT_PREFIX="You are "
CHATBOT_PROMPT_SUFFIX=".  Roleplay and never break character.  Do not use markdown in your responses, this is a text-only environment."
CHATBOT_PROMPT_SUFFIX_EXTRA=" Keep responses concise (under 400 chars) since this is IRC."
CHATBOT_MAX_TOKENS=1024
